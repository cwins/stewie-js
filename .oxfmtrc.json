{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "arrowParens": "always",
  "jsxSingleQuote": false,
  "printWidth": 140,
  "semi": true,
  "singleQuote": true,
  "tabWidth": 2,
  "trailingComma": "none",
  "useTabs": false,
  "ignorePatterns": ["node_modules/", "dist/", "pnpm-lock.yaml", "*.min.js", "*.md"]
}
