{
  "name": "ssr-and-routing",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist src/.temp-mocks",
    "nuke": "rm -rf dist src/.temp-mocks node_modules",
    "mock:clean": "rm -rf src/.temp-mocks",
    "mock:create-empty": "mkdir -p ./src/.temp-mocks && echo 'null' > ./src/.temp-mocks/data.json",
    "mock:create": "tsx src/get-mock-data.ts --overwrite",
    "dev": "tsx src/server.ts",
    "dev:temp-mock": "pnpm run mock:create && VITE_USE_TEMP_MOCK=true tsx src/server.ts",
    "build": "vite build && vite build --ssr",
    "build:temp-mock": "VITE_USE_TEMP_MOCK=true vite build && vite build --ssr",
    "preview": "NODE_ENV=production tsx src/server.ts",
    "start": "NODE_ENV=production node dist/server/server.js",
    "pretest": "pnpm run mock:create-empty",
    "test": "vitest run"
  },
  "dependencies": {
    "@stewie-js/adapter-node": "workspace:*",
    "@stewie-js/compiler": "workspace:*",
    "@stewie-js/core": "workspace:*",
    "@stewie-js/devtools": "workspace:*",
    "@stewie-js/router": "workspace:*",
    "@stewie-js/server": "workspace:*",
    "@stewie-js/testing": "workspace:*",
    "@stewie-js/vite": "workspace:*"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "tsx": "^4.0.0",
    "vite": "^7.0.0",
    "vitest": "^4.0.0"
  }
}
