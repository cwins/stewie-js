{
  "name": "@stewie-js/core",
  "version": "0.7.1",
  "description": "Reactivity primitives, JSX runtime, context, and control flow for the Stewie framework",
  "keywords": [
    "computed",
    "context",
    "effects",
    "jsx",
    "no-vdom",
    "reactive",
    "signals",
    "stewie",
    "store",
    "typescript",
    "web-framework"
  ],
  "homepage": "https://github.com/cwins/stewie-js/tree/main/packages/core#readme",
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cwins/stewie-js.git",
    "directory": "packages/core"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./jsx-dev-runtime": {
      "types": "./dist/jsx-dev-runtime.d.ts",
      "default": "./dist/jsx-dev-runtime.js"
    },
    "./jsx-runtime": {
      "types": "./dist/jsx-runtime.d.ts",
      "default": "./dist/jsx-runtime.js"
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "nuke": "rm -rf dist node_modules",
    "build": "tsc --build",
    "test": "vitest run"
  }
}
